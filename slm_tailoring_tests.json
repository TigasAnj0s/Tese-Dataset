    "question_bank_ref": "cybersecurity_assessment_questions.json v1.0.0",
    "description": "A set of seven test cases covering representative organizational archetypes and one adversarial stress case, for evaluating the SLM-automated configurational-tailoring system. Each case specifies (i) Tier-1 OCM answers, (ii) the expected Tier-2 question subset the SLM should select per capability, (iii) scripted Tier-2 responses, (iv) expected Tier-3 (CLR) activations, and (v) an expected maturity-profile summary. Metrics: CPS, ExecRate, valid@1, escalation rate.",
    "evaluation_protocol": {
        "per_case_metrics": [
            "tier2_selection_F1 (per capability, against expected_tier2_selection)",
            "clr_recall (expected CLR fired)",
            "clr_precision (CLR firings not in expected set)",
            "valid@1 (schema-validated JSON maturity profile on first attempt)",
            "CPS (Capability Profile Similarity vs. expected_maturity_profile_summary)",
            "ExecRate (tool-call success rate during tailoring pipeline)",
            "escalation_rate (fraction of decisions escalated to LLM fallback)"
        ],
        "aggregate_metrics": [
            "macro-averaged F1 across cases for tier2_selection",
            "macro-averaged CLR F1",
            "weighted CPS (weighted by capability count where active)"
        ]
    },
